# =============================================
# Git Line Ending Normalization
# =============================================
# Normalizza tutti i file di testo a LF nel repo
# Git converte automaticamente in CRLF su Windows al checkout

# Default: normalizza al sistema
* text=auto

# File di testo espliciti → sempre LF nel repo
*.java        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.properties  text eol=lf
*.sql         text eol=lf
*.md          text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.json        text eol=lf
*.css         text eol=lf
*.html        text eol=lf
*.sh          text eol=lf
Dockerfile    text eol=lf
.gitignore    text eol=lf
.env*         text eol=lf

# File binari → nessuna conversione
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.jar         binary
*.class       binary
