# BarberBook — Environment Variables Template
# =============================================
# Copia questo file in .env e compila i valori
# Il file .env NON deve mai essere committato in git
# =============================================

# ---- Database PostgreSQL ----
DB_USER=barberbook_user
DB_PASSWORD=change_me_in_production

# ---- JWT Secret (minimo 32 caratteri, consigliato 64) ----
# Genera con: openssl rand -base64 64
JWT_SECRET=change_me_with_a_very_long_and_secure_random_base64_secret_here

# ---- Account BAR (password iniziale — cambiare in produzione) ----
# Questo valore viene usato nella migrazione Flyway V3 per l'hash BCrypt
# Hash BCrypt strength 12 di 'admin1234' — CAMBIARE PRIMA DEL DEPLOY
BARBER_PASSWORD_HASH=$2a$12$PLACHOLDER_replace_with_real_bcrypt_hash

# ---- Profilo Spring ----
SPRING_PROFILES_ACTIVE=dev

# ---- URL base applicazione (per link email reset password) ----
APP_BASE_URL=http://localhost:3000

# ---- Email (opzionale — solo per produzione) ----
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password
